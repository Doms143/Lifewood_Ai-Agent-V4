    {
      "parameters": {
        "jsCode": "const webhookBody    = $('Receive Chat Message1').first().json.body;\nconst memoryData     = $('Fetch User Memory1').first().json;\nconst analyticsData  = $('Fetch Analytics Data1').first().json;\n\nconst userId          = webhookBody.user_id;\nconst userMessage     = webhookBody.message;\nconst conversationId  = webhookBody.conversation_id || null;\nconst history         = webhookBody.history || [];\n\n// Build analytics block\nconst summary  = analyticsData.summary  || {};\nconst byCategory = analyticsData.by_category || [];\nconst recent   = analyticsData.recent_receipts || [];\n\nconst analyticsBlock = `\n=== USER FINANCIAL SUMMARY ===\nTotal Receipts : ${summary.total_receipts    ?? 'N/A'}\nTotal Spent    : PHP ${summary.total_amount  ?? '0.00'}\nThis Month     : PHP ${summary.this_month    ?? '0.00'}\nLast Month     : PHP ${summary.last_month    ?? '0.00'}\nAvg per Receipt: PHP ${summary.average_amount ?? '0.00'}\n\nTop Categories:\n${byCategory.slice(0, 5).map(c => `  - ${c.category}: PHP ${c.total} (${c.count} receipts)`).join('\\n')}\n\nRecent Receipts (last 5):\n${recent.slice(0, 5).map(r => `  - ${r.expense_date} | ${r.business_name} | PHP ${r.total} | ${r.expense_category}`).join('\\n')}\n`.trim();\n\n// Build memory block\nconst memories = memoryData.messages || [];\nconst memoryBlock = memories.length > 0\n  ? `=== RELEVANT PAST CONVERSATIONS ===\\n${memories.map(m => `[${m.role}]: ${m.content}`).join('\\n')}`\n  : '';\n\n// System prompt\nconst systemPrompt = `You are Lifewood's AI finance assistant. You help users understand their expense history, receipts, and spending patterns.\n\nGuidelines:\n- Be concise and professional\n- Always reference actual data when answering\n- Format currency as PHP X,XXX.XX\n- If asked about something not in the data, say so honestly\n- You can only see this user's own data\n\n${analyticsBlock}\n\n${memoryBlock}`.trim();\n\n// Build messages array from history (last 10 turns)\nconst historyMessages = history.slice(-10).map(h => ({\n  role: h.role === 'agent' ? 'assistant' : 'user',\n  content: h.content\n}));\n\n// Final messages array for OpenAI\nconst messages = [\n  { role: 'system', content: systemPrompt },\n  ...historyMessages,\n  { role: 'user',   content: userMessage }\n];\n\nreturn [{\n  json: {\n    messages,\n    user_id: userId,\n    conversation_id: conversationId,\n    user_message: userMessage,\n  }\n}];"
      },
