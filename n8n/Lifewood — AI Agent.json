    {
      "parameters": {
        "jsCode": "const openaiResponse  = $('GPT-4o Chat').first().json;\nconst buildData       = $('Build System Prompt').first().json;\n\nconst replyText = openaiResponse?.choices?.[0]?.message?.content;\nif (!replyText) {\n  throw new Error('GPT-4o returned no reply content');\n}\n\nconst usage = openaiResponse.usage || {};\n\nreturn [{\n  json: {\n    reply:           replyText,\n    conversation_id: buildData.conversation_id,\n    user_id:         buildData.user_id,\n    metadata: {\n      model:              openaiResponse.model,\n      input_tokens:       usage.prompt_tokens,\n      output_tokens:      usage.completion_tokens,\n      total_tokens:       usage.total_tokens,\n    }\n  }\n}];"
      },
